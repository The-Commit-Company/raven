  "name": "@raven/web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --base=/assets/raven/raven_v3/ && yarn copy-html-entry",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "gen:colors": "node scripts/generate-espresso-colors.mjs",
    "gen:radius": "node scripts/generate-espresso-radius.mjs",
    "gen:typography": "node scripts/generate-espresso-typography.mjs",
    "gen:effects": "node scripts/generate-espresso-effects.mjs",
    "gen:tokens": "yarn gen:colors && yarn gen:radius && yarn gen:typography && yarn gen:effects",
    "copy-html-entry": "cp ../../raven/public/raven_v3/index.html ../../raven/www/raven_v3.html"
  },
